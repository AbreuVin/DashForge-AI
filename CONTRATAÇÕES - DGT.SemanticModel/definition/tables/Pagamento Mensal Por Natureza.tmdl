table 'Pagamento Mensal Por Natureza'
	lineageTag: ebcf3520-68f6-42c0-8ee9-6bf567c77675

	measure 'Executado dividido por Previsto' =
			
			DIVIDE(
				SUM('Pagamento Mensal Por Natureza'[Executado]),
				SUM('Pagamento Mensal Por Natureza'[Previsto])
			)
		formatString: #,0.00%;-#,0.00%;#,0.00%
		lineageTag: eaf3d018-1722-4f90-8948-d1186a7b16fb

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "MathematicalDivision"
				}

		changedProperty = FormatString

	measure exec/previst = ```
			
			DIVIDE(
			    CALCULATE(SUM('Pagamento Mensal Por Natureza'[Executado])),
			    CALCULATE(SUM('Pagamento Mensal Por Natureza'[Previsto]))
			)
			
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 5212bfcc-713b-4e2a-a658-8c099cebf098

	measure MediaExecutado = ```
			
			CALCULATE(
			    AVERAGE('Pagamento Mensal Por Natureza'[Executado]),
			    ALL('Calendario')
			)
			
			```
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: bbacb454-8e71-4ac1-b013-d32c3e9cd834

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure MesesComPagamento = ```
			
			CALCULATE(
			    DISTINCTCOUNT('Pagamento Mensal Por Natureza'[Mês]),
			    FILTER(
			        ALL('Pagamento Mensal Por Natureza'),
			        'Pagamento Mensal Por Natureza'[Executado] > 0
			            && 'Pagamento Mensal Por Natureza'[Ano] IN VALUES('Calendario'[Ano])
			    )
			)
			
			```
		formatString: 0
		lineageTag: 2d7dfdc9-2f4a-4c4d-9290-39be7b4117ba

	measure 'Meses Sem Pagamento (Com Corte)' = ```
			
			VAR AnoAtual = MAX('Calendario'[Ano])
			
			-- Primeiro mês com lançamento de pagamento no ano
			VAR PrimeiroMesComExecutadoNoAno =
			    CALCULATE(
			        MIN('Pagamento Mensal Por Natureza'[MesNumero]),
			        FILTER(
			            ALL('Pagamento Mensal Por Natureza'),
			            'Pagamento Mensal Por Natureza'[Executado] > 0 &&
			            'Pagamento Mensal Por Natureza'[Ano] = AnoAtual
			        )
			    )
			
			-- Verifica se teve qualquer lançamento no ano
			VAR TemLancamentoNoAno = NOT ISBLANK(PrimeiroMesComExecutadoNoAno)
			
			-- Conta quantos meses do ano atual tiveram pagamento
			VAR MesesComPagamento =
			    CALCULATE(
			        DISTINCTCOUNT('Pagamento Mensal Por Natureza'[MesNumero]),
			        FILTER(
			            'Pagamento Mensal Por Natureza',
			            'Pagamento Mensal Por Natureza'[Ano] = AnoAtual &&
			            'Pagamento Mensal Por Natureza'[Executado] > 0 &&
			            'Pagamento Mensal Por Natureza'[MesNumero] >= PrimeiroMesComExecutadoNoAno
			        )
			    )
			
			-- Total de meses "válidos" no ano: do 1º mês com execução até dezembro
			VAR MesesPossiveisNoAno =
			    IF(TemLancamentoNoAno, 13 - PrimeiroMesComExecutadoNoAno, 0)
			
			RETURN
			    MesesPossiveisNoAno - MesesComPagamento
			
			
			```
		formatString: 0
		lineageTag: 21943dd1-30b1-4b41-be95-44356600f3ed

	measure 'projeção pela média' = [MediaExecutado]*[Meses Sem Pagamento (Com Corte)]
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 35451284-febd-43ac-b502-b894d6b3972e

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'projeção soma' = [projeção pela média] + SUM('Pagamento Mensal Por Natureza'[Executado])
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 6852770e-c2d8-42b1-9a39-966ffad74948

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Executado ou Média (Corrigida e Segura)' = ```
			
			VAR AnoAtual = MAX('Calendario'[Ano])
			VAR MesAtual = MAX('Calendario'[MesNumero])
			
			-- Mês do primeiro lançamento no ano
			VAR PrimeiroMesComExecutadoNoAno =
			    CALCULATE(
			        MIN('Pagamento Mensal Por Natureza'[MesNumero]),
			        FILTER(
			            ALL('Pagamento Mensal Por Natureza'),
			            'Pagamento Mensal Por Natureza'[Executado] > 0 &&
			            'Pagamento Mensal Por Natureza'[Ano] = AnoAtual
			        )
			    )
			
			-- Verifica se o ano teve lançamento
			VAR TemLancamentoNoAno = NOT ISBLANK(PrimeiroMesComExecutadoNoAno)
			
			-- Executado no mês atual
			VAR ExecutadoNoMes =
			    CALCULATE(
			        SUM('Pagamento Mensal Por Natureza'[Executado]),
			        KEEPFILTERS('Calendario')
			    )
			
			RETURN
			    IF(
			        NOT TemLancamentoNoAno,
			        0,
			        IF(
			            MesAtual < PrimeiroMesComExecutadoNoAno,
			            0,
			            IF(
			                NOT ISBLANK(ExecutadoNoMes),
			                ExecutadoNoMes,
			                [MediaExecutado]
			            )
			        )
			    )
			
			
			```
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: 38134906-2046-44f1-befb-5dcb27c00981

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure Executado_Ate_D2 = ```
			
			VAR MesAtual = MONTH(TODAY())
			VAR AnoAtual = YEAR(TODAY())
			VAR MesLimite = MesAtual - 2
			
			RETURN
			CALCULATE(
			    SUM('Pagamento Mensal Por Natureza'[Executado]),
			    FILTER(
			        ALL('Pagamento Mensal Por Natureza'[MesAno]),
			        YEAR('Pagamento Mensal Por Natureza'[MesAno]) = AnoAtual &&
			        MONTH('Pagamento Mensal Por Natureza'[MesAno]) <= MesLimite
			    )
			)
			
			
			```
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: acdc2fb9-0c67-4488-8d84-f6e7a8d24404

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

