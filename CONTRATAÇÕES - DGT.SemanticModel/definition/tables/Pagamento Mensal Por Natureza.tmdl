	column Data = ```
			DATE(
			    'Pagamento Mensal Por Natureza'[Ano],
			    SWITCH(TRUE(),
			        'Pagamento Mensal Por Natureza'[Mês] = "Janeiro", 1,
			        'Pagamento Mensal Por Natureza'[Mês] = "Fevereiro", 2,
			        'Pagamento Mensal Por Natureza'[Mês] = "Março", 3,
			        'Pagamento Mensal Por Natureza'[Mês] = "Abril", 4,
			        'Pagamento Mensal Por Natureza'[Mês] = "Maio", 5,
			        'Pagamento Mensal Por Natureza'[Mês] = "Junho", 6,
			        'Pagamento Mensal Por Natureza'[Mês] = "Julho", 7,
			        'Pagamento Mensal Por Natureza'[Mês] = "Agosto", 8,
			        'Pagamento Mensal Por Natureza'[Mês] = "Setembro", 9,
			        'Pagamento Mensal Por Natureza'[Mês] = "Outubro", 10,
			        'Pagamento Mensal Por Natureza'[Mês] = "Novembro", 11,
			        'Pagamento Mensal Por Natureza'[Mês] = "Dezembro", 12,
			        BLANK()
			    ),
			    1
			)
			
			```
