table Dotação
	lineageTag: ad205442-b345-4b9b-b9fa-adca1568813f

	measure 'Saldo fixo 2025' =
			
			VAR Resultado =
			    CALCULATE(
			        SUM('Dotação'[Saldo Dotação]),
			        'Dotação'[Ano] = "2025",
			        REMOVEFILTERS('Cadastro de Contratos'),
			        REMOVEFILTERS('Pagamento Mensal Por Natureza'),
			        REMOVEFILTERS('Dotação'),
			        REMOVEFILTERS('Valor comprometido')
			    )
			RETURN
			    COALESCE(Resultado, 0)
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: dd1ba4f3-3688-4ab1-a15d-0400ee39135d

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Dotação Ano Fixo 2025' = ```
			
			VAR Resultado =
			    CALCULATE(
			        SUM('Dotação'[Dotação]),
			        'Dotação'[Ano] = "2025",
			        REMOVEFILTERS('Cadastro de Contratos'),
			        REMOVEFILTERS('Pagamento Mensal Por Natureza'),
			        REMOVEFILTERS('Dotação'),
			        REMOVEFILTERS('Valor comprometido')
			    )
			RETURN
			    COALESCE(Resultado, 0)
			
			```
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
