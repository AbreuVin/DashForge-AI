	column 'Valor Comprometido' = ```
			
			VAR SomaValores = 
			    SUMX(
			        RELATEDTABLE('Valor Comprometido'),
			        'Valor Comprometido'[Valor]
			    )
			RETURN SomaValores
			
			```
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: 00b2b35e-43c4-41d7-966f-fc151784510c
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	column 'Saldo Dotação' = 'Dotação'[Dotação] - 'Dotação'[Valor Comprometido]
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: 81daa94f-f0fa-4ba1-9391-0e5b7bf9ec7d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	column 'Contrato Lookup' = ```
			
			VAR TabelaRelacionada =
			    FILTER(
			        'valor comprometido',
			        'Valor Comprometido'[ID projeto.lookupValue] = 'dotação'[ID Pesquisa]
			    )
			RETURN
			    CALCULATE(
			        FIRSTNONBLANK('valor comprometido'[Contrato_.lookupValue], 1),
			        TabelaRelacionada
			    )
			
			```
		lineageTag: dbacf889-4c6b-4aa6-a670-4b9ed99f2579
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

