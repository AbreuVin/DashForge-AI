	measure Medida
		lineageTag: ad508b72-2612-4eec-afd9-d135cee4e2fd

		annotation 436ba87b-9c83-4389-a31b-ebd06a36be98 = {"Expression":null}

		annotation 277cc1b9-af89-4597-8e15-cacc25c0886b = Para usar caracteres especiais em um nome de medida, coloque todo o nome entre colchetes ( [] ) e adicione ] a quaisquer colchetes de fechamento no nome.

	measure previsto_exercicio_mespag = ```
			
			VAR MesAtual = MONTH(TODAY())
			VAR MesLimite = MesAtual - 2
			VAR MesLimitePositivo = IF(MesLimite > 0, MesLimite, 0)  -- Evita negativo
			
			RETURN
			    SUM('Cadastro de Contratos'[Previst exercicio por mes]) * MesLimitePositivo
			
			```
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: 6e8112fa-6e3f-4ed9-a955-e9db13f2825d

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

