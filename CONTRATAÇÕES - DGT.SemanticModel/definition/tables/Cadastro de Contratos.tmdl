table 'Cadastro de Contratos'
	lineageTag: fbae8867-975b-4999-9f7c-f101a71bad46

	measure 'Saldo Acumulativo' = ```
			
			VAR ContratoAditivoAtual = 
			    SELECTEDVALUE('Cadastro de Contratos'[Número do Contrato]) & "-" & 
			    SELECTEDVALUE('Cadastro de Contratos'[Número do Aditivo])
			
			VAR AnoAtual = SELECTEDVALUE('Cadastro de Contratos'[Ano de Desembolso])
			VAR ValorGlobal = MAX('Cadastro de Contratos'[Valor Global])
			
			-- Encontrar o primeiro ano do contrato + aditivo
			VAR PrimeiroAno = 
			    CALCULATE(
			        MIN('Cadastro de Contratos'[Ano de Desembolso]),
			        ALLEXCEPT('Cadastro de Contratos', 'Cadastro de Contratos'[Número do Contrato], 'Cadastro de Contratos'[Número do Aditivo])
			    )
			
			-- Para o primeiro ano, o saldo é: Valor Global - Executado
			VAR SaldoInicial = 
			    IF(AnoAtual = PrimeiroAno, 
			        ValorGlobal - 
			        CALCULATE(
			            SUM('Cadastro de Contratos'[Executado]),
			            'Cadastro de Contratos'[Ano de Desembolso] = PrimeiroAno
			        ),
			        BLANK()
			    )
			
			-- Acumulando os valores de execução até o ano atual
			VAR ExecutadoAcumulado = 
			    CALCULATE(
			        SUM('Cadastro de Contratos'[Executado]),
			        FILTER(
			            ALL('Cadastro de Contratos'),
			            'Cadastro de Contratos'[Número do Contrato] = SELECTEDVALUE('Cadastro de Contratos'[Número do Contrato]) &&
			            'Cadastro de Contratos'[Número do Aditivo] = SELECTEDVALUE('Cadastro de Contratos'[Número do Aditivo]) &&
			            'Cadastro de Contratos'[Ano de Desembolso] <= AnoAtual
			        )
			    )
			
			-- Cálculo do saldo para anos subsequentes
			RETURN 
			    IF(AnoAtual = PrimeiroAno, SaldoInicial, ValorGlobal - ExecutadoAcumulado)
			
			
			```
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: 2383578c-c8ed-44a2-9972-8f53c20d2a30

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure '%EXEC Acumulada' = ```
			
			VAR ContratoAditivoAtual = 
			    SELECTEDVALUE('Cadastro de Contratos'[Número do Contrato]) & "-" & 
			    SELECTEDVALUE('Cadastro de Contratos'[Número do Aditivo])
			
			VAR AnoAtual = SELECTEDVALUE('Cadastro de Contratos'[Ano de Desembolso])
			VAR ValorGlobal = MAX('Cadastro de Contratos'[Valor Global])
			
			-- Encontrar o primeiro ano do contrato + aditivo
			VAR PrimeiroAno = 
			    CALCULATE(
			        MIN('Cadastro de Contratos'[Ano de Desembolso]),
			        ALLEXCEPT('Cadastro de Contratos', 'Cadastro de Contratos'[Número do Contrato], 'Cadastro de Contratos'[Número do Aditivo])
			    )
			
			-- Para o primeiro ano, a % executada é Executado / Valor Global
			VAR PercentualInicial = 
			    IF(AnoAtual = PrimeiroAno, 
			        DIVIDE(
			            CALCULATE(
			                SUM('Cadastro de Contratos'[Executado]),
			                'Cadastro de Contratos'[Ano de Desembolso] = PrimeiroAno
			            ), 
			            ValorGlobal, 
			            0
			        ),
			        BLANK()
			    )
			
			-- Acumulando os valores de execução até o ano atual
			VAR ExecutadoAcumulado = 
			    CALCULATE(
			        SUM('Cadastro de Contratos'[Executado]),
			        FILTER(
			            ALL('Cadastro de Contratos'),
			            'Cadastro de Contratos'[Número do Contrato] = SELECTEDVALUE('Cadastro de Contratos'[Número do Contrato]) &&
			            'Cadastro de Contratos'[Número do Aditivo] = SELECTEDVALUE('Cadastro de Contratos'[Número do Aditivo]) &&
			            'Cadastro de Contratos'[Ano de Desembolso] <= AnoAtual
			        )
			    )
			
			-- Cálculo da % para anos subsequentes
			RETURN 
			    IF(AnoAtual = PrimeiroAno, PercentualInicial, DIVIDE(ExecutadoAcumulado, ValorGlobal, 0))
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 1fea9700-6e5f-494d-8b21-bc546948ae2d

	measure '%EXEC Anual' = ```
			
			VAR ContratoAditivoAtual = 
			    SELECTEDVALUE('Cadastro de Contratos'[Número do Contrato]) & "-" & 
			    SELECTEDVALUE('Cadastro de Contratos'[Número do Aditivo])
			
			VAR AnoAtual = SELECTEDVALUE('Cadastro de Contratos'[Ano de Desembolso])
			VAR ValorGlobal = MAX('Cadastro de Contratos'[Valor do Exercicio])
			
			VAR ExecutadoAnoAtual = 
			    CALCULATE(
			        SUM('Cadastro de Contratos'[Executado]),
			        FILTER(
			            ALL('Cadastro de Contratos'),
			            'Cadastro de Contratos'[Número do Contrato] = SELECTEDVALUE('Cadastro de Contratos'[Número do Contrato]) &&
			            'Cadastro de Contratos'[Número do Aditivo] = SELECTEDVALUE('Cadastro de Contratos'[Número do Aditivo]) &&
			            'Cadastro de Contratos'[Ano de Desembolso] = AnoAtual
			        )
			    )
			
			RETURN 
			    DIVIDE(ExecutadoAnoAtual, ValorGlobal, 0)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 297352b2-6bbd-4c34-979d-6699e303c411

	measure 3card = ```
			
			CALCULATE(
			    SUM('Cadastro de Contratos'[Executado]),
			    YEAR('Cadastro de Contratos'[Ano de Desembolso]) = 2025
			)
			/
			[Dotação Ano Fixo 2025]
			
			```
		formatString: #,0.00%;-#,0.00%;#,0.00%
		lineageTag: 05e2f1a4-5cf7-487f-a03c-8d7ac19865da

	measure 'Executado Acumulado' = ```
			
			VAR ContratoAditivoAtual = 
			    SELECTEDVALUE('Cadastro de Contratos'[Número do Contrato]) & "-" & 
			    SELECTEDVALUE('Cadastro de Contratos'[Número do Aditivo])
			
			VAR AnoAtual = SELECTEDVALUE('Cadastro de Contratos'[Ano de Desembolso])
			
			-- Acumulando os valores de execução até o ano atual
			VAR ExecutadoAcumulado = 
			    CALCULATE(
			        SUM('Cadastro de Contratos'[Executado]),
			        FILTER(
			            ALL('Cadastro de Contratos'),
			            'Cadastro de Contratos'[Número do Contrato] = SELECTEDVALUE('Cadastro de Contratos'[Número do Contrato]) &&
			            'Cadastro de Contratos'[Número do Aditivo] = SELECTEDVALUE('Cadastro de Contratos'[Número do Aditivo]) &&
			            'Cadastro de Contratos'[Ano de Desembolso] <= AnoAtual
			        )
			    )
			
			RETURN ExecutadoAcumulado
			
			```
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
