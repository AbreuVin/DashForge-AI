	column Status_Contrato = ```
			
			IF (
			    LEFT('Cadastro de Contratos'[Nome da Empresa], 3) = "DOD",
			    "Ativo",
			    IF (
			        'Cadastro de Contratos'[Data Final - Vigência] > TODAY(),
			        "Ativo",
			        "Não Ativo"
			    )
			)
			
			```
