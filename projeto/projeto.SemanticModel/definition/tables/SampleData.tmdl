table SampleData
	lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567890

	measure TotalReceita = CALCULATE(SUM(SampleData[Valor]), SampleData[Categoria] = "Receita Total")
		formatString: R$ #,##0
		lineageTag: e5f6a7b8-c9d0-1234-efab-345678901234

	measure UsuariosAtivos = CALCULATE(SUM(SampleData[Valor]), SampleData[Categoria] = "Usuários Ativos")
		formatString: #,##0
		lineageTag: f6a7b8c9-d0e1-2345-fabc-456789012345

	measure Satisfacao = CALCULATE(SUM(SampleData[Valor]), SampleData[Categoria] = "Satisfação") / 100
		formatString: 0.0%
		lineageTag: a7b8c9d0-e1f2-3456-abcd-567890123456

	measure HtmlCardReceita =
			VAR _valor = [TotalReceita]
			VAR _meta = CALCULATE(SUM(SampleData[Meta]), SampleData[Categoria] = "Receita Total")
			VAR _percent = DIVIDE(_valor, _meta, 0) * 100
			RETURN
			"<div style='font-family: Segoe UI, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px; padding: 24px; color: white; box-shadow: 0 8px 32px rgba(102,126,234,0.3);'>" &
			"<p style='margin:0; font-size:12px; opacity:0.8; text-transform:uppercase; letter-spacing:1px;'>Receita Total</p>" &
			"<h2 style='margin:8px 0; font-size:32px; font-weight:700;'>R$ " & FORMAT(_valor, "#,##0") & "</h2>" &
			"<div style='background:rgba(255,255,255,0.2); border-radius:8px; height:6px; margin-top:12px;'>" &
			"<div style='background:white; border-radius:8px; height:6px; width:" & FORMAT(_percent, "0") & "%;'></div></div>" &
			"<p style='margin:4px 0 0; font-size:11px; opacity:0.7;'>" & FORMAT(_percent, "0.0") & "% da meta</p>" &
			"</div>"
		lineageTag: b8c9d0e1-f2a3-4567-bcde-678901234567

	measure HtmlGlassCard =
			VAR _valor = [TotalReceita]
			VAR _meta = CALCULATE(SUM(SampleData[Meta]), SampleData[Categoria] = "Receita Total")
			VAR _percent = DIVIDE(_valor - _meta, _meta, 0) * 100
			RETURN
			"<style>@keyframes br{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}@keyframes gp{0%,100%{text-shadow:0 0 20px rgba(99,102,241,0.3)}50%{text-shadow:0 0 40px rgba(99,102,241,0.8),0 0 60px rgba(99,102,241,0.4)}}.gb{padding:2px;border-radius:20px;background:linear-gradient(270deg,#6366F1,#06B6D4,#EC4899,#8B5CF6);background-size:300% 300%;animation:br 4s ease infinite}.gi{background:#0D0D1A;border-radius:18px}.gn{animation:gp 2s ease-in-out infinite}</style>" &
			"<div class='gb' style='width:100%;height:100vh;box-sizing:border-box;font-family:Segoe UI,sans-serif;color:white;'>" &
			"<div class='gi' style='width:100%;height:100%;box-sizing:border-box;padding:min(24px,4vh) min(24px,4vw);display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden;'>" &
			"<div style='position:absolute;top:-50%;right:-50%;width:100%;height:100%;background:radial-gradient(circle,rgba(99,102,241,0.15) 0%,transparent 70%);'></div>" &
			"<div style='display:flex;align-items:center;gap:8px;margin:0 0 min(12px,2vh);position:relative;'><svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='#A78BFA' stroke-width='2' stroke-linecap='round'><line x1='12' y1='1' x2='12' y2='23'/><path d='M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'/></svg><span style='font-size:min(11px,2.5vw);text-transform:uppercase;letter-spacing:1.5px;color:rgba(255,255,255,0.5);'>Receita Mensal</span></div>" &
			"<div class='gn' style='font-size:min(36px,8vw);font-weight:700;background:linear-gradient(135deg,#6366F1,#A78BFA);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:min(16px,3vh);position:relative;'>R$ " & FORMAT(_valor, "#,##0") & "</div>" &
			"<div style='display:flex;align-items:center;gap:6px;font-size:min(13px,2.5vw);color:#4ADE80;position:relative;'>" &
			"<span style='padding:2px 6px;background:rgba(74,222,128,0.1);border-radius:4px;font-size:min(11px,2vw);'>▲ " & FORMAT(ABS(_percent), "0.0") & "%</span> vs. mês anterior</div></div></div>"
		lineageTag: 11111111-1111-1111-1111-111111111111

	measure HtmlNeonCard =
			VAR _valor = [UsuariosAtivos]
			VAR _meta = CALCULATE(SUM(SampleData[Meta]), SampleData[Categoria] = "Usuários Ativos")
			VAR _percent = DIVIDE(_valor - _meta, _meta, 0) * 100
			RETURN
			"<style>@keyframes br{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}@keyframes gp{0%,100%{text-shadow:0 0 15px rgba(6,182,212,0.3)}50%{text-shadow:0 0 30px rgba(6,182,212,0.8)}}.gb{padding:2px;border-radius:20px;background:linear-gradient(270deg,#06B6D4,#8B5CF6,#EC4899,#06B6D4);background-size:300% 300%;animation:br 4s ease infinite}.gi{background:#0D0D1A;border-radius:18px}.gn{animation:gp 2s ease-in-out infinite}</style>" &
			"<div class='gb' style='width:100%;height:100vh;box-sizing:border-box;font-family:Segoe UI,sans-serif;color:white;'>" &
			"<div class='gi' style='width:100%;height:100%;box-sizing:border-box;padding:min(24px,4vh) min(24px,4vw);display:flex;flex-direction:column;justify-content:center;position:relative;'>" &
			"<div style='display:flex;justify-content:space-between;align-items:center;margin-bottom:min(20px,3vh);'>" &
			"<div style='width:min(40px,8vw);height:min(40px,8vw);border-radius:12px;display:flex;align-items:center;justify-content:center;background:rgba(6,182,212,0.15);box-shadow:0 0 20px rgba(6,182,212,0.1);'><svg width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='#06B6D4' stroke-width='2' stroke-linecap='round'><path d='M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M22 21v-2a4 4 0 0 0-3-3.87'/><path d='M16 3.13a4 4 0 0 1 0 7.75'/></svg></div>" &
			"<span style='font-size:min(11px,2.5vw);padding:4px 10px;border-radius:20px;background:rgba(74,222,128,0.1);color:#4ADE80;font-weight:500;'>+" & FORMAT(ABS(_percent), "0.0") & "%</span></div>" &
			"<div class='gn' style='font-size:min(32px,7vw);font-weight:700;margin-bottom:4px;'>" & FORMAT(_valor, "#,##0") & "</div>" &
			"<div style='font-size:min(12px,2.5vw);color:#6B7280;'>Usuários Ativos</div>" &
			"<div style='position:absolute;bottom:0;left:16px;right:16px;height:2px;background:linear-gradient(90deg,#06B6D4,#8B5CF6,#EC4899);border-radius:2px;'></div></div></div>"
		lineageTag: 22222222-2222-2222-2222-222222222222

	measure HtmlProgressCard =
			VAR _valor = CALCULATE(SUM(SampleData[Valor]), SampleData[Categoria] = "Receita Total")
			VAR _meta = CALCULATE(SUM(SampleData[Meta]), SampleData[Categoria] = "Receita Total")
			VAR _percent = DIVIDE(_valor, _meta, 0) * 100
			VAR _falta = _meta - _valor
			RETURN
			"<style>@keyframes br{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}@keyframes fb{from{width:0%}}@keyframes gp{0%,100%{text-shadow:0 0 15px rgba(139,92,246,0.3)}50%{text-shadow:0 0 30px rgba(139,92,246,0.8)}}.gb{padding:2px;border-radius:20px;background:linear-gradient(270deg,#8B5CF6,#6366F1,#06B6D4,#8B5CF6);background-size:300% 300%;animation:br 4s ease infinite}.gi{background:#0D0D1A;border-radius:18px}.gn{animation:gp 2s ease-in-out infinite}.ab{animation:fb 1.5s ease-out forwards}</style>" &
			"<div class='gb' style='width:100%;height:100vh;box-sizing:border-box;font-family:Segoe UI,sans-serif;color:white;'>" &
			"<div class='gi' style='width:100%;height:100%;box-sizing:border-box;padding:min(24px,4vh) min(24px,4vw);display:flex;flex-direction:column;justify-content:center;'>" &
			"<div style='display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:min(20px,3vh);'>" &
			"<div><div style='display:flex;align-items:center;gap:6px;margin:0 0 8px;'><svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='#8B5CF6' stroke-width='2' stroke-linecap='round'><circle cx='12' cy='12' r='10'/><circle cx='12' cy='12' r='6'/><circle cx='12' cy='12' r='2'/></svg><span style='font-size:min(13px,2.5vw);color:#9CA3AF;'>Meta de Vendas</span></div>" &
			"<div class='gn' style='font-size:min(28px,6vw);font-weight:700;'>R$ " & FORMAT(_valor, "#,##0") & "</div></div>" &
			"<div style='font-size:min(24px,5vw);font-weight:600;color:#8B5CF6;'>" & FORMAT(_percent, "0") & "%</div></div>" &
			"<div style='background:rgba(255,255,255,0.06);border-radius:6px;height:min(8px,1.5vh);overflow:hidden;margin-bottom:min(12px,2vh);'>" &
			"<div class='ab' style='height:100%;border-radius:6px;background:linear-gradient(90deg,#8B5CF6,#6366F1,#06B6D4);width:" & FORMAT(_percent, "0") & "%;'></div></div>" &
			"<div style='display:flex;justify-content:space-between;font-size:min(11px,2vw);color:#6B7280;'>" &
			"<span>R$ " & FORMAT(_valor / 1000, "#,##0") & "k de R$ " & FORMAT(_meta / 1000, "#,##0") & "k</span>" &
			"<span>Faltam R$ " & FORMAT(ABS(_falta) / 1000, "#,##0") & "k</span></div></div></div>"
		lineageTag: 33333333-3333-3333-3333-333333333333

	measure HtmlSparkCard =
			VAR _valor = CALCULATE(SUM(SampleData[Valor]), SampleData[Categoria] = "Ticket Médio")
			RETURN
			"<style>@keyframes br{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}@keyframes fb{from{height:0%}}@keyframes gp{0%,100%{text-shadow:0 0 15px rgba(99,102,241,0.3)}50%{text-shadow:0 0 30px rgba(99,102,241,0.8)}}.gb{padding:2px;border-radius:20px;background:linear-gradient(270deg,#6366F1,#8B5CF6,#4ADE80,#6366F1);background-size:300% 300%;animation:br 4s ease infinite}.gi{background:#0D0D1A;border-radius:18px}.gn{animation:gp 2s ease-in-out infinite}.sb{animation:fb 0.8s ease-out both}</style>" &
			"<div class='gb' style='width:100%;height:100vh;box-sizing:border-box;font-family:Segoe UI,sans-serif;color:white;'>" &
			"<div class='gi' style='width:100%;height:100%;box-sizing:border-box;padding:min(24px,4vh) min(24px,4vw);display:flex;flex-direction:column;justify-content:center;'>" &
			"<div style='display:flex;align-items:center;gap:6px;margin:0 0 min(6px,1vh);'><svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='#6366F1' stroke-width='2' stroke-linecap='round'><line x1='18' y1='20' x2='18' y2='10'/><line x1='12' y1='20' x2='12' y2='4'/><line x1='6' y1='20' x2='6' y2='14'/></svg><span style='font-size:min(12px,2.5vw);color:#6B7280;'>Vendas Semanais</span></div>" &
			"<div style='display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:min(16px,3vh);'>" &
			"<div class='gn' style='font-size:min(28px,6vw);font-weight:700;'>R$ " & FORMAT(_valor * 149, "#,##0") & "</div>" &
			"<div style='font-size:min(13px,2.5vw);color:#4ADE80;font-weight:500;'>+8.3%</div></div>" &
			"<div style='display:flex;align-items:flex-end;gap:3px;height:min(40px,15vh);flex:1;'>" &
			"<div class='sb' style='flex:1;height:45%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0s;'></div>" &
			"<div class='sb' style='flex:1;height:60%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0.05s;'></div>" &
			"<div class='sb' style='flex:1;height:35%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0.1s;'></div>" &
			"<div class='sb' style='flex:1;height:75%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0.15s;'></div>" &
			"<div class='sb' style='flex:1;height:55%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0.2s;'></div>" &
			"<div class='sb' style='flex:1;height:90%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0.25s;'></div>" &
			"<div class='sb' style='flex:1;height:70%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0.3s;'></div>" &
			"<div class='sb' style='flex:1;height:85%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0.35s;'></div>" &
			"<div class='sb' style='flex:1;height:65%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0.4s;'></div>" &
			"<div class='sb' style='flex:1;height:95%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0.45s;'></div>" &
			"<div class='sb' style='flex:1;height:80%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0.5s;'></div>" &
			"<div class='sb' style='flex:1;height:100%;background:linear-gradient(to top,rgba(99,102,241,0.3),rgba(99,102,241,0.8));border-radius:3px 3px 0 0;animation-delay:0.55s;'></div>" &
			"</div></div></div>"
		lineageTag: 44444444-4444-4444-4444-444444444444

	measure HtmlStatusCard =
			VAR _satisf = [Satisfacao] * 100
			VAR _conversao = CALCULATE(SUM(SampleData[Valor]), SampleData[Categoria] = "Conversão")
			RETURN
			"<style>@keyframes br{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}@keyframes p{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.6;transform:scale(.8)}}@keyframes fs{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}.gb{padding:2px;border-radius:20px;background:linear-gradient(270deg,#4ADE80,#06B6D4,#8B5CF6,#4ADE80);background-size:300% 300%;animation:br 4s ease infinite}.gi{background:#0D0D1A;border-radius:18px}.pulse{animation:p 2s infinite}.fi{animation:fs 0.5s ease-out both}</style>" &
			"<div class='gb' style='width:100%;height:100vh;box-sizing:border-box;font-family:Segoe UI,sans-serif;color:white;'>" &
			"<div class='gi' style='width:100%;height:100%;box-sizing:border-box;padding:min(24px,4vh) min(24px,4vw);display:flex;flex-direction:column;justify-content:center;'>" &
			"<div style='display:flex;justify-content:space-between;align-items:center;margin-bottom:min(20px,3vh);'>" &
			"<div style='display:flex;align-items:center;gap:8px;font-size:min(14px,3vw);font-weight:600;'><svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='#4ADE80' stroke-width='2' stroke-linecap='round'><polyline points='22 12 18 12 15 21 9 3 6 12 2 12'/></svg>Saúde do Sistema</div>" &
			"<div class='pulse' style='width:8px;height:8px;border-radius:50%;background:#4ADE80;box-shadow:0 0 12px rgba(74,222,128,0.4);'></div></div>" &
			"<div style='display:grid;grid-template-columns:1fr 1fr;gap:min(16px,3vh);'>" &
			"<div class='fi' style='animation-delay:0.1s;'><p style='margin:0 0 4px;font-size:min(11px,2.5vw);color:#6B7280;'>Uptime</p><div style='font-size:min(20px,4.5vw);font-weight:600;color:#4ADE80;'>99.9%</div></div>" &
			"<div class='fi' style='animation-delay:0.2s;'><p style='margin:0 0 4px;font-size:min(11px,2.5vw);color:#6B7280;'>Latência</p><div style='font-size:min(20px,4.5vw);font-weight:600;color:#06B6D4;'>42ms</div></div>" &
			"<div class='fi' style='animation-delay:0.3s;'><p style='margin:0 0 4px;font-size:min(11px,2.5vw);color:#6B7280;'>Erros/min</p><div style='font-size:min(20px,4.5vw);font-weight:600;color:#F87171;'>0.3</div></div>" &
			"<div class='fi' style='animation-delay:0.4s;'><p style='margin:0 0 4px;font-size:min(11px,2.5vw);color:#6B7280;'>Req/seg</p><div style='font-size:min(20px,4.5vw);font-weight:600;color:#8B5CF6;'>1.2k</div></div>" &
			"</div></div></div>"
		lineageTag: 55555555-5555-5555-5555-555555555555

	measure HtmlGaugeCard =
			VAR _satisf = [Satisfacao] * 100
			VAR _dashoffset = 339.292 * (1 - _satisf / 100)
			RETURN
			"<style>@keyframes br{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}@keyframes dr{from{stroke-dashoffset:339.292}}@keyframes gp{0%,100%{text-shadow:0 0 15px rgba(6,182,212,0.3)}50%{text-shadow:0 0 30px rgba(6,182,212,0.8)}}.gb{padding:2px;border-radius:20px;background:linear-gradient(270deg,#6366F1,#06B6D4,#4ADE80,#6366F1);background-size:300% 300%;animation:br 4s ease infinite}.gi{background:#0D0D1A;border-radius:18px}.ar{animation:dr 2s ease-out forwards}.gn{animation:gp 2s ease-in-out infinite}</style>" &
			"<div class='gb' style='width:100%;height:100vh;box-sizing:border-box;font-family:Segoe UI,sans-serif;color:white;'>" &
			"<div class='gi' style='width:100%;height:100%;box-sizing:border-box;padding:16px;text-align:center;display:flex;flex-direction:column;align-items:center;justify-content:center;'>" &
			"<p style='margin:0 0 8px;font-size:min(12px,2.5vw);color:#6B7280;text-transform:uppercase;letter-spacing:1px;'>Satisfação do Cliente</p>" &
			"<div style='width:min(120px,30vw,30vh);height:min(120px,30vw,30vh);margin:0 auto 8px;position:relative;'>" &
			"<svg width='100%' height='100%' viewBox='0 0 120 120' style='transform:rotate(-90deg);'>" &
			"<defs><linearGradient id='gg' x1='0%' y1='0%' x2='100%' y2='0%'><stop offset='0%' style='stop-color:#6366F1;'/><stop offset='100%' style='stop-color:#06B6D4;'/></linearGradient></defs>" &
			"<circle cx='60' cy='60' r='54' fill='none' stroke='rgba(255,255,255,0.06)' stroke-width='8'/>" &
			"<circle class='ar' cx='60' cy='60' r='54' fill='none' stroke='url(#gg)' stroke-width='8' stroke-linecap='round' stroke-dasharray='339.292' stroke-dashoffset='" & FORMAT(_dashoffset, "0.0") & "'/>" &
			"</svg>" &
			"<div class='gn' style='position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:min(28px,6vw);font-weight:700;'>" & FORMAT(_satisf, "0.0") & "%</div></div>" &
			"<div style='display:flex;align-items:center;justify-content:center;gap:6px;margin:0;font-size:min(13px,2.5vw);color:#9CA3AF;'><svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='#4ADE80' stroke-width='2' stroke-linecap='round'><polyline points='20 6 9 17 4 12'/></svg>Meta: 90% atingida</div></div></div>"
		lineageTag: 66666666-6666-6666-6666-666666666666

	measure HtmlAnimatedCard =
			VAR _receita = [TotalReceita]
			VAR _metaReceita = CALCULATE(SUM(SampleData[Meta]), SampleData[Categoria] = "Receita Total")
			VAR _pctReceita = DIVIDE(_receita, _metaReceita, 0) * 100
			VAR _usuarios = [UsuariosAtivos]
			VAR _metaUsuarios = CALCULATE(SUM(SampleData[Meta]), SampleData[Categoria] = "Usuários Ativos")
			VAR _pctUsuarios = DIVIDE(_usuarios, _metaUsuarios, 0) * 100
			VAR _satisf = [Satisfacao] * 100
			VAR _score = (_pctReceita + _pctUsuarios + _satisf) / 3
			RETURN
			"<style>" &
			"@keyframes br{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}" &
			"@keyframes gp{0%,100%{text-shadow:0 0 20px rgba(99,102,241,0.3)}50%{text-shadow:0 0 40px rgba(99,102,241,0.8),0 0 60px rgba(99,102,241,0.4)}}" &
			"@keyframes fb{from{width:0%}}" &
			"@keyframes fs{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}" &
			".gb{padding:2px;border-radius:20px;background:linear-gradient(270deg,#6366F1,#06B6D4,#EC4899,#8B5CF6);background-size:300% 300%;animation:br 4s ease infinite}" &
			".gi{background:#12121F;border-radius:18px;padding:min(24px,4vh) min(24px,4vw)}" &
			".gn{animation:gp 2s ease-in-out infinite}" &
			".ab{height:6px;border-radius:3px;animation:fb 1.5s ease-out forwards}" &
			".ar{animation:fs 0.5s ease-out both}" &
