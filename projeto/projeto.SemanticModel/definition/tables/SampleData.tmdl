			"<div class='ind'><div style='display:flex;align-items:center;gap:10px;'><div style='width:8px;height:8px;border-radius:50%;background:#EC4899;box-shadow:0 0 8px rgba(236,72,153,0.4);'></div><span style='font-size:13px;color:#9CA3AF;'>Ticket Médio</span></div><span style='font-size:14px;font-weight:600;color:#fff;'>R$ " & FORMAT(_ticket, "#,##0") & "</span></div>" &
			"</div></div>" &
			"<div style='height:2px;background:linear-gradient(90deg,#6366F1,#06B6D4,#EC4899);border-radius:2px;margin-top:16px;'></div>" &
