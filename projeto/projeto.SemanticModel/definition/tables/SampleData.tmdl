	measure ExecKpiReceita =
			VAR _val = [TotalReceita]
			VAR _meta = CALCULATE(SUM(SampleData[Meta]), SampleData[Categoria] = "Receita Total")
			VAR _pct = DIVIDE(_val, _meta, 0) * 100
			VAR _up = _val >= _meta
			RETURN
			"<div style='width:100%;height:100vh;box-sizing:border-box;font-family:Segoe UI,sans-serif;background:#14142B;border-radius:16px;border:1px solid rgba(99,102,241,.15);padding:clamp(12px,3vh,20px);display:flex;flex-direction:column;justify-content:center;'>" &
			"<div style='display:flex;align-items:center;gap:6px;margin-bottom:8px;'>" &
			"<div style='width:28px;height:28px;border-radius:8px;background:rgba(99,102,241,.15);display:flex;align-items:center;justify-content:center;'>" &
			"<svg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='#6366F1' stroke-width='2'><line x1='12' y1='1' x2='12' y2='23'/><path d='M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'/></svg></div>" &
			"<span style='font-size:min(10px,2.2vw);text-transform:uppercase;letter-spacing:1px;color:#6B7280;'>Receita</span></div>" &
			"<div style='font-size:min(26px,5.5vw);font-weight:700;color:#fff;margin-bottom:6px;'>R$ " & FORMAT(_val / 1000, "#,##0") & "K</div>" &
			"<div style='display:flex;align-items:center;gap:6px;'>" &
			"<div style='padding:2px 8px;border-radius:6px;font-size:min(11px,2.4vw);font-weight:600;" & IF(_up, "background:rgba(74,222,128,.12);color:#4ADE80;'>▲ ", "background:rgba(248,113,113,.12);color:#F87171;'>▼ ") & FORMAT(_pct, "0.0") & "%</div>" &
			"<span style='font-size:min(10px,2.2vw);color:#6B7280;'>da meta</span></div></div>"
		lineageTag: e1000001-exec-4001-a001-000000000001

