	partition SampleData = calculated
		mode: import
		source =
				DATATABLE(
					"Categoria", STRING,
					"Valor", DOUBLE,
					"Meta", DOUBLE,
					{
						{"Receita Total", 1250000, 1000000},
						{"Usuários Ativos", 8432, 10000},
						{"Satisfação", 94.5, 90},
						{"Conversão", 12.8, 15},
						{"Ticket Médio", 285.50, 250}
					}
				)

