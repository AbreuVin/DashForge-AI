			"<div class='gn' style='font-size:min(48px,10vw);font-weight:700;margin-bottom:min(16px,3vh);'>" & FORMAT(_score, "0.0") & "<span style='font-size:min(20px,4vw);color:#8B5CF6;'>%</span></div>" &
			"<div class='ar' style='margin-bottom:min(10px,2vh);animation-delay:0.2s;'>" &
