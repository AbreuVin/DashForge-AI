			"<div style='background:rgba(255,255,255,0.06);border-radius:3px;height:min(6px,1.2vh);'><div class='ab' style='width:" & FORMAT(_pctReceita, "0") & "%;background:linear-gradient(90deg,#4ADE80,#06B6D4);'></div></div></div>" &
			"<div class='ar' style='margin-bottom:min(10px,2vh);animation-delay:0.4s;'>" &
			"<div style='display:flex;justify-content:space-between;font-size:min(11px,2.5vw);color:#9CA3AF;margin-bottom:4px;'><span>Usuários</span><span style='color:#8B5CF6;'>" & FORMAT(_pctUsuarios, "0") & "%</span></div>" &
			"<div style='background:rgba(255,255,255,0.06);border-radius:3px;height:min(6px,1.2vh);'><div class='ab' style='width:" & FORMAT(_pctUsuarios, "0") & "%;background:linear-gradient(90deg,#8B5CF6,#6366F1);animation-delay:0.3s;'></div></div></div>" &
