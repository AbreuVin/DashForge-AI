			"<div style='display:flex; align-items:center; gap:8px; margin:5px 0;'><svg width='18' height='18' viewBox='0 0 24 24' fill='none'><circle cx='12' cy='12' r='10' fill='#BC4749'/><line x1='8' y1='8' x2='16' y2='16' stroke='white' stroke-width='2.5' stroke-linecap='round'/><line x1='16' y1='8' x2='8' y2='16' stroke='white' stroke-width='2.5' stroke-linecap='round'/></svg><span style='font-size:12px; color:#283618;'>CRM migration issue</span></div>" &
			"</div>"
		lineageTag: 11111111-2222-3333-4444-555555666607

	measure SagePeriodBadge =
