	partition SalesTeamData = calculated
		mode: import
		source =
				DATATABLE(
					"Team", STRING,
					"Rep", STRING,
					"Revenue", DOUBLE,
					"Target", DOUBLE,
					"Pipeline", DOUBLE,
					"Status", STRING,
					{
						{"Alpha", "Ana Silva", 45000, 50000, 62000, "Won"},
						{"Alpha", "Bruno Costa", 38000, 45000, 55000, "Won"},
						{"Alpha", "Carlos Lima", 22000, 40000, 48000, "Lost"},
						{"Beta", "Diana Reis", 52000, 55000, 70000, "Won"},
						{"Beta", "Eduardo Nunes", 41000, 50000, 45000, "Won"},
						{"Beta", "Fernanda Souza", 18000, 45000, 38000, "Lost"},
						{"Gamma", "Gabriel Rocha", 30000, 55000, 42000, "Lost"},
						{"Gamma", "Helena Dias", 25000, 50000, 35000, "Lost"},
						{"Gamma", "Igor Santos", 35000, 48000, 50000, "Won"},
						{"Delta", "Julia Ferreira", 48000, 50000, 65000, "Won"},
						{"Delta", "Kevin Moreira", 42000, 45000, 58000, "Won"},
						{"Delta", "Laura Alves", 33000, 40000, 40000, "Won"},
						{"Epsilon", "Miguel Cardoso", 20000, 55000, 30000, "Lost"},
						{"Epsilon", "Natalia Ribeiro", 28000, 50000, 42000, "Won"},
						{"Epsilon", "Oscar Pereira", 15000, 45000, 25000, "Lost"}
					}
				)

