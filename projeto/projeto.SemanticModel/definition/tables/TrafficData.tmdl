		sourceColumn: [Source]

	column Category
		lineageTag: cc333333-3333-3333-3333-333333333333
		isNameInferred
		sourceColumn: [Category]

	column Value
		lineageTag: cc444444-4444-4444-4444-444444444444
		isNameInferred
		sourceColumn: [Value]

	partition TrafficData = calculated
