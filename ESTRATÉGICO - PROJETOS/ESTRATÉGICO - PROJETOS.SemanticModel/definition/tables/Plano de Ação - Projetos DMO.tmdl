	column SetorNovo =
			
			IF(
			    'Plano de Ação - Projetos DMO'[Setor] IN {"COSIS", "CSJUD"},
			    "DMO",
			    "AXÉLAB"
			)
		lineageTag: c4001649-00e5-4dc5-943f-64beb3a83ee8
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column StatusClassificado = ```
			
			VAR StatusAtual = 'Plano de Ação - Projetos DMO'[Status]
			VAR DataEntrega = 'Plano de Ação - Projetos DMO'[Entrega Prevista]
			VAR DataEntregaReal = 'Plano de Ação - Projetos DMO'[Entrega Prevista]
			VAR Hoje = TODAY()
			
			RETURN
			SWITCH(
			    TRUE(),
			
			    -- Se for CANCELADO ou SUSPENSO, mantém
			    StatusAtual IN { "CANCELADO", "SUSPENSO" },
			        StatusAtual,
			    
			    -- ENTREGUE dentro ou fora do prazo
			    StatusAtual = "ENTREGUE" && NOT(ISBLANK(DataEntregaReal)),
			        "ENTREGUE",
			    
			    -- ATRASADO: ainda não entregue e a data de entrega já passou
			    StatusAtual <> "ENTREGUE" && NOT(ISBLANK(DataEntrega)) && Hoje > DataEntrega,
			        "ATRASADO",
			
			    -- Caso contrário, mantém o status original
			    TRUE,
			        StatusAtual
			)
			
			
			```
		lineageTag: 9b7979f5-f76d-492d-9acd-173f5055de56
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

