	column %conc = ```
			
			VAR ValorBruto = 
			    IF(
			        ISBLANK('Plano de Ação - Projetos DMO'[% Concluído]),
			        'Plano de Ação - Projetos DMO'[Progresso],
			        'Plano de Ação - Projetos DMO'[% Concluído]
			    )
			VAR ValorNumerico = IFERROR(VALUE(ValorBruto), 0)
			
			-- Se o valor for maior que 1 (ex: 87), divide por 100. 
			-- O TRUNC garante que 0,8762 não vire 0,88
			VAR Resultado = IF(ValorNumerico > 1, ValorNumerico / 100, ValorNumerico)
			
			RETURN TRUNC(Resultado, 4)
			```
		dataType: double
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 59b54799-2cd1-4ade-9e75-788c47c2e4d5
		summarizeBy: sum

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

