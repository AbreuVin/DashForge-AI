table 'Plano de Ação - Projetos DMO'
	lineageTag: 4af4cd28-b484-42f5-9cb6-53a2b29d28cb

	measure DataMenos3Meses =
			
			EDATE(TODAY(), -6)
		formatString: General Date
		lineageTag: ddd43d08-701e-4240-93d9-579965ac9199

	measure 'Total Projetos Ativos' =
			
			CALCULATE(
			    COUNTROWS('Plano de Ação - Projetos DMO'),
			    'Plano de Ação - Projetos DMO'[Situação] IN { "Desenvolvimento", "Especificação", "Homologado", "Homologação" }
			)
		formatString: 0
		lineageTag: a0713798-1328-4a9c-bf46-15c462c770da

	measure 'Titulo Projeto' = SELECTEDVALUE('Plano de Ação - Projetos DMO'[Nome da tarefa], "Projeto")
		lineageTag: e7b5a90c-a380-4804-be6a-28ec081fba03

	measure 'Projetos Em Dia' =
			CALCULATE(
			    'Plano de Ação - Projetos DMO'[Total Projetos Ativos],
			    'Plano de Ação - Projetos DMO'[Status Geral] = "Em dia"
			) + 0
		formatString: 0
		lineageTag: 463778ae-447e-4c9b-ad59-3edc52407f12

	measure 'Projetos Requer Ajuda' =
			CALCULATE(
			    'Plano de Ação - Projetos DMO'[Total Projetos Ativos],
			    'Plano de Ação - Projetos DMO'[Status Geral] = "Requer ajuda"
			) + 0
		formatString: 0
		lineageTag: 80e7522e-4df0-48ba-9d1a-799eb7094375

	measure 'Projetos Em Risco' =
			CALCULATE(
			    'Plano de Ação - Projetos DMO'[Total Projetos Ativos],
			    'Plano de Ação - Projetos DMO'[Status Geral] = "Em risco"
			) + 0
		formatString: 0
		lineageTag: ddb0e561-7480-4ca7-89c3-6be40c58d14c

	measure ExibirHistorico = IF(ISFILTERED('Plano de Ação - Projetos DMO'[Projeto]), 1, 0)
		formatString: 0
		lineageTag: 5d96b6ed-47e0-476c-a1d6-fde6783e2d14

