	column Status_Validacao_Coluna =
			
			VAR Indice = Medicao[Índice]
			VAR DiasMes = DAY(EOMONTH(Medicao[UltimoDiaMes], 0))
			
			VAR ValorFaixaLicenca =
			    SWITCH(
			        TRUE(),
			        ISBLANK(Indice), BLANK(),
			        Indice >= 0    && Indice <= 1000, 60,
			        Indice >= 1001 && Indice <= 2000, 55,
			        Indice >= 2001 && Indice <= 3000, 50,
			        Indice >= 3001 && Indice <= 3228, 45,
			        BLANK()
			    )
			
			VAR ValorLicenca =
			    DIVIDE(ValorFaixaLicenca, DiasMes) * Medicao[Licenças-dia_calculada]
			
			VAR ValorPacote =
			    DIVIDE(40, DiasMes) * Medicao[Licenças-dia_calculada]
			
			VAR ValorTotal =
			    ROUND(COALESCE(ValorLicenca, 0) + COALESCE(ValorPacote, 0), 2)
			
			VAR TotalLinha =
			    ROUND(Medicao[Total (R$)], 2)
			
			RETURN
			    IF(
			        ABS(ValorTotal - TotalLinha) <= 0.01,
			        "Dados Conciliados",
			        "Divergência encontrada"
			    )
		lineageTag: c4cae81d-5427-40e6-b0f3-e23924b11e3c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition Medicao = m
		mode: import
		source =
				let
				    // ===== PARÂMETROS =====
				    Site = "https://tjbacotec.sharepoint.com/sites/axelab-controle-elosminuta-prd",
				    PastaAlvo = "https://tjbacotec.sharepoint.com/sites/axelab-controle-elosminuta-prd/Documentos Compartilhados/medicao/",
				    Prefixo = "medicao-tjba",
				
				    // ===== FONTE SHAREPOINT =====
				    Fonte = SharePoint.Files(Site, [ApiVersion = 15]),
				
				    // ===== FILTRA TODOS OS ARQUIVOS medicao-tjba*.csv NA PASTA =====
				    ArquivosFiltrados =
				        Table.SelectRows(
				            Fonte,
				            each
				                [Folder Path] = PastaAlvo
				                and Text.StartsWith([Name], Prefixo)
				                and Text.EndsWith(Text.Lower([Name]), ".csv")
				        ),
				
				    // ===== FUNÇÃO PARA TRANSFORMAR CADA CSV =====
				    TransformarArquivo = (Conteudo as binary, NomeArquivo as text) as table =>
				        let
				            CSVImportado =
				                Csv.Document(
				                    Conteudo,
				                    [Delimiter=";", Columns=8, Encoding=65001, QuoteStyle=QuoteStyle.None]
				                ),
				
				            TipoAlterado =
				                Table.TransformColumnTypes(
				                    CSVImportado,
				                    {
				                        {"Column1", type text}, {"Column2", type text}, {"Column3", type text}, {"Column4", type text},
				                        {"Column5", type text}, {"Column6", type text}, {"Column7", type text}, {"Column8", type text}
				                    }
				                ),
				
				            // --- captura "Período" dentro do PRÓPRIO arquivo ---
				            PeriodoTexto =
				                try Table.SelectRows(TipoAlterado, each [Column1] = "Período"){0}[Column2] otherwise null,
				
				            UltimoDiaMes =
				                if PeriodoTexto = null then null
				                else
				                    let
				                        Partes = Text.Split(PeriodoTexto, " a "),
				                        DataFimTexto = Text.Trim(Partes{1})
				                    in
				                        Date.FromText(DataFimTexto, "pt-BR"),
				
				            // --- remove cabeçalho fixo do arquivo ---
				            LinhasSuperioresRemovidas = Table.Skip(TipoAlterado, 27),
				            CabecalhosPromovidos = Table.PromoteHeaders(LinhasSuperioresRemovidas, [PromoteAllScalars=true]),
				
				            // --- tipagem conforme seu layout ---
				            TipoAlterado1 =
				                Table.TransformColumnTypes(
				                    CabecalhosPromovidos,
				                    {
				                        {"Nome", type text},
				                        {"Email", type text},
				                        {"Ativado em", type date},
				                        {"Licenças-dia", Int64.Type},
				                        {"Licenças médias", Int64.Type},
				                        {"Licenciamento (R$)", Currency.Type},
				                        {"Pacote (R$)", Currency.Type},
				                        {"Total (R$)", Currency.Type}
				                    }
				                ),
				
				            // --- adiciona datas de competência ---
				            UltimoDiaMesAdicionado =
				                Table.AddColumn(TipoAlterado1, "UltimoDiaMes", each UltimoDiaMes, type date),
				
				            PrimeiroDiaMesAdicionado =
				                Table.AddColumn(
				                    UltimoDiaMesAdicionado,
				                    "PrimeiroDiaMes",
				                    each Date.StartOfMonth([UltimoDiaMes]),
				                    type date
				                ),
				
				            // --- ajustes finais de tipos monetários ---
				            TipoAlterado2 =
				                Table.TransformColumnTypes(
				                    PrimeiroDiaMesAdicionado,
				                    {
				                        {"Licenciamento (R$)", Currency.Type},
				                        {"Pacote (R$)", Currency.Type},
				                        {"Total (R$)", Currency.Type}
				                    }
				                ),
				
				            // --- rastreio do arquivo de origem ---
				            ComArquivoOrigem =
				                Table.AddColumn(TipoAlterado2, "Arquivo_Origem", each NomeArquivo, type text)
				
				        in
				            ComArquivoOrigem,
				
				    // ===== APLICA A FUNÇÃO EM CADA ARQUIVO E CONSOLIDA =====
				    AdicionarTabelas =
				        Table.AddColumn(
				            ArquivosFiltrados,
				            "Tabela",
				            each TransformarArquivo([Content], [Name]),
				            type table
				        ),
				
				    Consolidado = Table.Combine(AdicionarTabelas[Tabela]),
				
				    // ===== PADRONIZA NOME (Primeira letra maiúscula) =====
				    NomeCapitalizado =
				        Table.TransformColumns(
				            Consolidado,
				            {{"Nome", each Text.Proper(Text.Lower(_)), type text}}
				        ),
				
				    // ===== ORDENA PARA O ÍNDICE FICAR CONSISTENTE (POR ATIVADO EM) =====
				    Ordenado =
				        Table.Sort(
				            NomeCapitalizado,
				            {
				                {"Arquivo_Origem", Order.Ascending},
				                {"Ativado em", Order.Ascending},
				                {"Nome", Order.Ascending},
				                {"Email", Order.Ascending}
				            }
				        ),
				
				    // ===== ÍNDICE QUE REINICIA POR ARQUIVO =====
				    Agrupado =
				        Table.Group(
				            Ordenado,
				            {"Arquivo_Origem"},
				            {
				                {
				                    "Dados",
				                    (t as table) => Table.AddIndexColumn(t, "Índice_Arquivo", 1, 1, Int64.Type),
				                    type table
				                }
				            }
				        ),
				
				    // pega as colunas internas (agora inclui Índice_Arquivo)
				    ColunasDados =
				        if Table.RowCount(Agrupado) = 0
				        then {}
				        else Table.ColumnNames(Agrupado{0}[Dados]),
				
				    // não expande Arquivo_Origem de novo (já é chave do grupo)
				    ColunasParaExpandir = List.RemoveItems(ColunasDados, {"Arquivo_Origem"}),
				
				    Expandido =
				        Table.ExpandTableColumn(
				            Agrupado,
				            "Dados",
				            ColunasParaExpandir,
				            ColunasParaExpandir
				        ),
				
				    #"Tipo Alterado" = Table.TransformColumnTypes(Expandido,{{"Índice_Arquivo", Int64.Type}}),
				    #"Colunas Renomeadas" = Table.RenameColumns(#"Tipo Alterado",{{"Índice_Arquivo", "Índice"}}),
				    #"Tipo Alterado1" =
				        Table.TransformColumnTypes(
				            #"Colunas Renomeadas",
				            {
				                {"Nome", type text},
