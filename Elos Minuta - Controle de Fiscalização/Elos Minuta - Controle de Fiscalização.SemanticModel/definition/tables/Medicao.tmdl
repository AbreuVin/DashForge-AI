	measure 'Periodo Selecionado' =
			
			VAR MinD = MIN ( Medicao[PrimeiroDiaMes] )
			VAR MaxD = MAX ( Medicao[UltimoDiaMes] )
			RETURN
			IF (
			    ISBLANK ( MinD ) || ISBLANK ( MaxD ),
			    "Período: (sem filtro)",
			    "Período: " & FORMAT ( MinD, "dd/mm/yyyy" ) & " a " & FORMAT ( MaxD, "dd/mm/yyyy" )
			)
		lineageTag: cc75f416-0196-4028-a3e2-cc1345c25f9a

	measure 'Titulo - Painel Executivo' =
			
