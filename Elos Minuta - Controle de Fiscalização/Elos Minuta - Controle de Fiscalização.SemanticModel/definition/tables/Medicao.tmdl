table Medicao
	lineageTag: 9fb226be-ad2a-491f-b435-4c65792cd898

	measure 'Valor_Faixa_Licenca (medida)' =
			
			SUMX(
			    Medicao,
			    VAR Indice = Medicao[Índice]
			    RETURN
			        SWITCH(
			            TRUE(),
			            ISBLANK(Indice), BLANK(),
			            Indice >= 0    && Indice <= 1000, 60.00,
			            Indice >= 1001 && Indice <= 2000, 55.00,
			            Indice >= 2001 && Indice <= 3000, 50.00,
			            Indice >= 3001 && Indice <= 3228, 45.00,
			            BLANK()
			        )
			)
		lineageTag: 2d7a3ee6-441f-4efa-97c0-f53a5ce61995

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Dias_Mes_Selecionado =
			
			VAR DataRef = MAX ( Medicao[UltimoDiaMes] )
			RETURN
			DAY ( EOMONTH ( DataRef, 0 ) )
		formatString: 0
		lineageTag: e2a9d188-03ca-4e1f-b368-e063f77b35c9

	measure Valor_Faixa_Licenca_por_Dia =
			
			DIVIDE(
			    [Valor_Faixa_Licenca (medida)],
			    [Dias_Mes_Selecionado]
			)
		lineageTag: 6445835a-ce70-4723-b3b3-8290c023c507

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Valor_Licenca =
			
			SUMX(
			    Medicao,
			    [Valor_Faixa_Licenca_por_Dia] * Medicao[Licenças-dia_calculada]
			)
		formatString: "R$"#,0.00;-"R$"#,0.00;"R$"#,0.00
		lineageTag: b108994a-50d3-4931-bd8c-898feb04f9d3

		annotation PBI_FormatHint = {"currencyCulture":"es-BR"}

	measure Quantidade_User_Ativo = COUNTROWS(Medicao)
		formatString: #,0
		lineageTag: 33cd3130-8dc2-4321-98e8-450ca318585c

	measure 'Valor_Faixa_Pacote (medida)' = 40
		formatString: 0
		lineageTag: 04bf9284-355b-4efe-bf16-9b59eea1df4f

	measure Valor_Faixa_Pacote_por_Dia =
			
			DIVIDE(
			    [Valor_Faixa_Pacote (medida)],
			    [Dias_Mes_Selecionado]
			)
		lineageTag: 0e0c2f5a-6f64-4382-8647-f756f938d1d0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Valor_Pacote =
			
			SUMX(
			    Medicao,
			    [Valor_Faixa_Pacote_por_Dia] * Medicao[Licenças-dia_calculada]
			)
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
