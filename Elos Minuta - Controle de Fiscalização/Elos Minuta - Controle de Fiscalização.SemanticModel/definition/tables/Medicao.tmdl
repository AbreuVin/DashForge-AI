	measure Ultima_Atualizacao = ```
			
			"Dados atualizados em "
			& FORMAT ( NOW() - TIME(3,0,0), "dd/MM/yyyy" )
			& " às "
			& FORMAT ( NOW() - TIME(3,0,0), "HH:mm" )
			
			```
		lineageTag: 47fe65b6-2fde-42f3-a4e8-ddedcdb34282

	measure Status_Validacao = ```
			
			VAR Valor1 = COALESCE([Valor_Total], 0)
			VAR Valor2 = COALESCE(SUM(Medicao[Total (R$)]), 0)
			VAR Diferenca = ABS(Valor1 - Valor2)
			RETURN
			    IF(
			        Diferenca <= 0.01,
			        "✅ Dados Conciliados",
			        "❌ Divergência encontrada"
			    )
			
			```
		lineageTag: 408295a6-485e-4483-8855-13e01f95c2d9

