	column Licenças-dia_calculada = ```
			
			VAR DataAtivacao = Medicao[Ativado em]
			VAR UltimoDiaMes = Medicao[UltimoDiaMes]
			VAR PrimeiroDiaMes =
			    DATE(
			        YEAR(UltimoDiaMes),
			        MONTH(UltimoDiaMes),
			        1
			    )
			VAR TotalDiasMes =
			    DAY(UltimoDiaMes)
			RETURN
			IF(
			    ISBLANK(DataAtivacao) || ISBLANK(UltimoDiaMes),
			    0,
			    IF(
			        DataAtivacao < PrimeiroDiaMes,
			        TotalDiasMes,
			        DATEDIFF(
			            DataAtivacao,
			            UltimoDiaMes,
			            DAY
			        ) + 1
			    )
			)
			
			```
		formatString: 0
		lineageTag: e51ef854-4a43-42d1-803f-1cad48814575
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

