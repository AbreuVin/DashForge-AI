	measure Valor_Total_Com_Infra = ```
			
			SUMX(
			    {
			        [Valor_Licenca],
			        [Valor_Pacote],
			        [Valor_Infra]
			    },
			    COALESCE ( [Value], 0 )
			)
			
			```
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
