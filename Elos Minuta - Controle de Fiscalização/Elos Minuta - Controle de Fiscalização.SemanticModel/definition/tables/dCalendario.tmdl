	partition dCalendario = calculated
		mode: import
		source = ```
				
				VAR DataInicial =
				    MIN ( Medicao[PrimeiroDiaMes] )
				
				VAR DataFinal =
				    MAX ( Medicao[UltimoDiaMes] )
				
				RETURN
				ADDCOLUMNS (
				    CALENDAR ( DataInicial, DataFinal ),
				
				    "Ano", YEAR ( [Date] ),
				    "Mês Número", MONTH ( [Date] ),
				    "Mês", FORMAT ( [Date], "MMMM", "pt-BR" ),
				    "Ano-Mês", FORMAT ( [Date], "MMM/yyyy", "pt-BR" ),
				    "AnoMes_Ordem", YEAR([Date]) * 100 + MONTH([Date]),
				    "Trimestre", "T" & FORMAT([Date], "Q"),
				    "Dia", DAY([Date])
				)
				
				```

	annotation PBI_Id = fb099ce676a341a290376f3ba9f93e04

