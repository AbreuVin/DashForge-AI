	column 'Autorizado Em'
		dataType: dateTime
		formatString: dd/mm/yyyy hh:nn
		lineageTag: 8a1d3cf8-32ba-4e4a-a455-9139c351d39a
		summarizeBy: none
		sourceColumn: Autorizado Em

		variation Variation
			isDefault
			relationship: 536b7b1a-6c13-47c4-b9b9-611d850384ab
			defaultHierarchy: LocalDateTable_635331da-7153-4270-8efc-65013f936e45.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	column 'Registrado Em'
		dataType: dateTime
		formatString: Short Date
		lineageTag: c345a95d-d192-4cfb-9b24-8a2885ea3f48
		summarizeBy: none
		sourceColumn: Registrado Em

		variation Variation
			isDefault
			relationship: f65f1bb4-098b-4194-85c1-123c457cf8e5
			defaultHierarchy: LocalDateTable_c0148919-28ed-43e3-952b-216038a73864.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column Domínio_Email =
			
			VAR Email = LOWER ( Usuarios_Sistema[Email] )
			RETURN
			IF(
			    ISBLANK(Email),
			    "Email em branco",
			    IF(
			        RIGHT(Email, LEN("tjba.jus.br")) = "tjba.jus.br",
			        "Dentro do domínio TJBA",
			        "Fora do domínio TJBA"
			    )
			)
		lineageTag: 771e6223-6111-46a0-8ade-11b446e5b2f2
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'BASE AZURE - EMAILS.userPrincipalName'
