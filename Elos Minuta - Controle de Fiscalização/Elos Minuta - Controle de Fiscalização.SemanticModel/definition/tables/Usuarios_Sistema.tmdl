	column 'Localização Mapa_Calc' =
			
			VAR c =
			    TRIM(Usuarios_Sistema[BASE AZURE - EMAILS.Comarca])
			RETURN
			IF(
			    c = "" || ISBLANK(c),
			    BLANK(),
			    c & ", Bahia, Brasil"
			)
		lineageTag: b6de3241-bb3c-49c9-879b-2e7802525883
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition Usuarios_Sistema = m
		mode: import
		source =
				let
				    // ===== PARÂMETROS =====
				    Site = "https://tjbacotec.sharepoint.com/sites/axelab-controle-elosminuta-prd",
				    PastaAlvo = "https://tjbacotec.sharepoint.com/sites/axelab-controle-elosminuta-prd/Documentos Compartilhados/usuarios/",
				
				    // ===== FONTE SHAREPOINT =====
				    Fonte = SharePoint.Files(Site, [ApiVersion = 15]),
				
				    // ===== FILTRA ARQUIVOS usuarios_sistema*.csv =====
				    ArquivosFiltrados =
				        Table.SelectRows(
				            Fonte,
				            each
				                [Folder Path] = PastaAlvo
				                and Text.Contains(Text.Lower([Name]), "usuarios_sistema")
				                and Text.EndsWith(Text.Lower([Name]), ".csv")
				        ),
				
				    // ===== PEGA O PRIMEIRO ARQUIVO ENCONTRADO =====
				    ConteudoArquivo = ArquivosFiltrados{0}[Content],
				
				    #"CSV Importado" =
				        Csv.Document(
				            ConteudoArquivo,
				            [Delimiter=",", Columns=6, Encoding=65001, QuoteStyle=QuoteStyle.None]
				        ),
				
				    #"Cabeçalhos Promovidos" =
				        Table.PromoteHeaders(#"CSV Importado", [PromoteAllScalars=true]),
				
				    #"Tipo Alterado" =
				        Table.TransformColumnTypes(
				            #"Cabeçalhos Promovidos",
				            {
				                {"Email", type text},
				                {"Nome", type text},
				                {"Status", type text},
				                {"Cadastrado", type text},
				                {"Autorizado Em", type datetime},
				                {"Registrado Em", type text}
				            }
				        ),
				
				    #"Consultas Mescladas" =
				        Table.NestedJoin(
				            #"Tipo Alterado",
				            {"Email"},
				            #"BASE AZURE - EMAILS",
				            {"userPrincipalName"},
				            "BASE AZURE - EMAILS",
				            JoinKind.LeftOuter
				        ),
				
				    #"BASE AZURE - EMAILS Expandido" =
				        Table.ExpandTableColumn(
				            #"Consultas Mescladas",
				            "BASE AZURE - EMAILS",
				            {"userPrincipalName", "displayName", "Perfil", "Comarca", "Vara"},
				            {"BASE AZURE - EMAILS.userPrincipalName", "BASE AZURE - EMAILS.displayName", "BASE AZURE - EMAILS.Perfil", "BASE AZURE - EMAILS.Comarca", "BASE AZURE - EMAILS.Vara"}
				        ),
				
				    #"Valor Substituído" =
				        Table.ReplaceValue(
				            #"BASE AZURE - EMAILS Expandido",
				            "-",
				            "",
				            Replacer.ReplaceText,
				            {"Registrado Em"}
				        ),
				
				    #"Texto Extraído Antes do Delimitador" =
				        Table.TransformColumns(
				            #"Valor Substituído",
				            {{"Registrado Em", each Text.BeforeDelimiter(_, ","), type text}}
				        ),
				
				    #"Tipo Alterado1" =
				        Table.TransformColumnTypes(
				            #"Texto Extraído Antes do Delimitador",
				            {{"Registrado Em", type date}}
				        ),
				
				    #"Colocar Cada Palavra Em Maiúscula" =
				        Table.TransformColumns(
				            #"Tipo Alterado1",
				            {
				                {"BASE AZURE - EMAILS.displayName", Text.Proper, type text},
				                {"BASE AZURE - EMAILS.Comarca", Text.Proper, type text},
				                {"BASE AZURE - EMAILS.Vara", Text.Proper, type text}
				            }
				        ),
				
				    #"Valor Substituído1" =
				        Table.ReplaceValue(
				            #"Colocar Cada Palavra Em Maiúscula",
				            "ACTIVE",
				            "Ativo",
				            Replacer.ReplaceText,
				            {"Status"}
				        ),
				
				    #"Valor Substituído2" =
				        Table.ReplaceValue(
				            #"Valor Substituído1",
				            "PENDING",
				            "Pendente",
				            Replacer.ReplaceText,
				            {"Status"}
				        )
				
				in
				    #"Valor Substituído2"

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Table

