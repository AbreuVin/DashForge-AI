table Usuarios_Sistema
	lineageTag: e8c9b700-de46-4a9e-877a-bcdb900d31d6

	measure 'Titulo Usuários' =
			
			"Usuários do Sistema "
		lineageTag: 69a9a33b-c4f5-43e0-a0ef-e48cc2393ad4

	measure Qtde_Users = COUNTROWS(Usuarios_Sistema)
		formatString: #,0
		lineageTag: a8d11086-16e8-4264-b8d9-dd03fc6bf6da

	measure 'Titulo Mapa' =
			
			"Mapa "
		lineageTag: fe8570bd-4047-4095-bb03-afe198df9aa5

	measure 'Qtde_Users Ativos' =
			
			CALCULATE(
			    COUNTROWS(Usuarios_Sistema),
			    Usuarios_Sistema[Status] = "Ativo"
			)
		formatString: #,0
		lineageTag: e627ebd1-fce8-4c5a-8bc3-2e57608fe3f5

	measure 'Qtde_Users Pendente' =
			
			CALCULATE(
			    COUNTROWS(Usuarios_Sistema),
			    Usuarios_Sistema[Status] = "Pendente"
			)
		formatString: 0
		lineageTag: 3f28f760-f5dc-47fb-ad35-b30910305a64

	measure 'Qtde_Users Inativo' =
			
			CALCULATE(
			    COUNTROWS(Usuarios_Sistema),
			    Usuarios_Sistema[Status] = "INAtivo"
			)
		formatString: 0
		lineageTag: 2adcdf51-1c90-4f1f-a176-c8057368064c

	measure Faixa_Usuarios =
			
			SWITCH(
			    TRUE(),
			    [Qtde_Users] <= 10, "Até 10",
			    [Qtde_Users] <= 50, "11 a 50",
			    [Qtde_Users] <= 100, "51 a 100",
			    [Qtde_Users] <= 200, "101 a 200",
			    "Acima de 200"
			)
		lineageTag: 4dab603c-ab69-4db9-aa56-b2faa8c3f56d

	measure Total_Comarcas =
			
			DISTINCTCOUNT(Usuarios_Sistema[BASE AZURE - EMAILS.Comarca])
		formatString: 0
		lineageTag: 9d18f649-cc4a-4052-bff7-b36295960e84

	measure Top_Comarca =
			
			VAR Top1 =
			    TOPN(
			        1,
			        SUMMARIZE(
			            Usuarios_Sistema,
			            Usuarios_Sistema[BASE AZURE - EMAILS.Comarca],
			            "Qtd", COUNTROWS(Usuarios_Sistema)
			        ),
			        [Qtd], DESC,
			        Usuarios_Sistema[BASE AZURE - EMAILS.Comarca], ASC
			    )
			RETURN
			    CONCATENATEX(
			        Top1,
			        Usuarios_Sistema[BASE AZURE - EMAILS.Comarca],
			        ", "
			    )
		lineageTag: 3fc50da6-04d8-4c29-8d39-357c5fe25a71

	measure Top_Comarca_Qtd =
			
			VAR Top1 =
			    TOPN(
			        1,
			        SUMMARIZE(
			            Usuarios_Sistema,
			            Usuarios_Sistema[BASE AZURE - EMAILS.Comarca],
			            "Qtd", COUNTROWS(Usuarios_Sistema)
			        ),
			        [Qtd], DESC,
			        Usuarios_Sistema[BASE AZURE - EMAILS.Comarca], ASC
			    )
			RETURN
			    MAXX(Top1, [Qtd])
		formatString: 0
		lineageTag: 7d4c608b-3800-4016-a2e3-a5fba510e2be

	measure Top_Comarca_Card =
			
			VAR Top1 =
			    TOPN(
			        1,
			        SUMMARIZE(
			            Usuarios_Sistema,
			            Usuarios_Sistema[BASE AZURE - EMAILS.Comarca],
			            "Qtd", COUNTROWS(Usuarios_Sistema)
			        ),
			        [Qtd], DESC,
			        Usuarios_Sistema[BASE AZURE - EMAILS.Comarca], ASC
			    )
			VAR NomeComarca =
			    CONCATENATEX(
			        Top1,
			        Usuarios_Sistema[BASE AZURE - EMAILS.Comarca],
			        ", "
			    )
			VAR QtdComarca =
			    MAXX(Top1, [Qtd])
			RETURN
			    NomeComarca & " - " & FORMAT(QtdComarca, "#,0")
		lineageTag: 20a6bd5c-75d3-4f7e-9f7c-053178f62609

	measure Ranking_Comarca =
			
			VAR ComarcaAtual =
			    SELECTEDVALUE(Usuarios_Sistema[BASE AZURE - EMAILS.Comarca])
			RETURN
			RANKX(
			    ALL(Usuarios_Sistema[BASE AZURE - EMAILS.Comarca]),
			    CALCULATE([Qtde_Users]),
			    CALCULATE(
			        [Qtde_Users],
			        Usuarios_Sistema[BASE AZURE - EMAILS.Comarca] = ComarcaAtual
			    ),
			    DESC,
			    DENSE
			)
		formatString: 0
		lineageTag: 72a11b3d-f1d1-4f2c-bf5c-8a39c6befe26

	measure Ranking_Formatado =
			
			FORMAT([Ranking_Comarca], "0") & "º"
		lineageTag: ab898739-352d-4fa9-b2ba-12b1478aaa9c

