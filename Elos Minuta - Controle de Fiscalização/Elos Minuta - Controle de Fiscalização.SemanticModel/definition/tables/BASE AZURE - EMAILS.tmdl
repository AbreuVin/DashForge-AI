				            #"Tipo Alterado",
				            {"displayName"},
				            #"VIEW CODES - ESTAGIц│RIOS",
				            {"NOME"},
				            "VIEW CODES - ESTAGIц│RIOS",
				            JoinKind.LeftOuter
				        ),
				
				    #"VIEW CODES - ESTAGIц│RIOS Expandido" =
				        Table.ExpandTableColumn(
				            #"Consultas Mescladas",
				            "VIEW CODES - ESTAGIц│RIOS",
				            {"EMAIL", "NOME", "MATRICULA", "CPF", "NIVEL_ESCOLARIDADE", "COMARCA", "LOTACAO", "DESC_CURSO", "DATA_INICIO_ESTAGIO", "DATA_FIM_ESTAGIO"},
				            {"VIEW CODES - ESTAGIц│RIOS.EMAIL", "VIEW CODES - ESTAGIц│RIOS.NOME", "VIEW CODES - ESTAGIц│RIOS.MATRICULA", "VIEW CODES - ESTAGIц│RIOS.CPF", "VIEW CODES - ESTAGIц│RIOS.NIVEL_ESCOLARIDADE", "VIEW CODES - ESTAGIц│RIOS.COMARCA", "VIEW CODES - ESTAGIц│RIOS.LOTACAO", "VIEW CODES - ESTAGIц│RIOS.DESC_CURSO", "VIEW CODES - ESTAGIц│RIOS.DATA_INICIO_ESTAGIO", "VIEW CODES - ESTAGIц│RIOS.DATA_FIM_ESTAGIO"}
				        ),
				
				    #"Consultas Mescladas1" =
				        Table.NestedJoin(
				            #"VIEW CODES - ESTAGIц│RIOS Expandido",
				            {"userPrincipalName"},
				            #"VIEW SEGESP -  SERVIDORES",
				            {"EMAIL_INSTITUCIONAL"},
				            "VIEW SEGESP -  SERVIDORES",
				            JoinKind.LeftOuter
				        ),
				
				    #"VIEW SEGESP -  SERVIDORES Expandido" =
				        Table.ExpandTableColumn(
				            #"Consultas Mescladas1",
				            "VIEW SEGESP -  SERVIDORES",
				            {"MATRICULA", "TIPO_MATRICULA", "CPF", "ID_UNIDADE", "EMAIL_INSTITUCIONAL", "ID_TJBASEG", "STATUS", "TIPO_SERVIDOR", "CODG_CARGO_ATUAL", "DESC_CARGO_ATUAL", "NOME", "UNIDADE", "ID_COMARCA", "COMARCA"},
				            {"VIEW SEGESP -  SERVIDORES.MATRICULA", "VIEW SEGESP -  SERVIDORES.TIPO_MATRICULA", "VIEW SEGESP -  SERVIDORES.CPF", "VIEW SEGESP -  SERVIDORES.ID_UNIDADE", "VIEW SEGESP -  SERVIDORES.EMAIL_INSTITUCIONAL", "VIEW SEGESP -  SERVIDORES.ID_TJBASEG", "VIEW SEGESP -  SERVIDORES.STATUS", "VIEW SEGESP -  SERVIDORES.TIPO_SERVIDOR", "VIEW SEGESP -  SERVIDORES.CODG_CARGO_ATUAL", "VIEW SEGESP -  SERVIDORES.DESC_CARGO_ATUAL", "VIEW SEGESP -  SERVIDORES.NOME", "VIEW SEGESP -  SERVIDORES.UNIDADE", "VIEW SEGESP -  SERVIDORES.ID_COMARCA", "VIEW SEGESP -  SERVIDORES.COMARCA"}
				        ),
				
				    #"Coluna Condicional Adicionada" =
				        Table.AddColumn(
				            #"VIEW SEGESP -  SERVIDORES Expandido",
				            "Perfil",
				            each
				                let
				                    MatEstagiario = [#"VIEW CODES - ESTAGIц│RIOS.MATRICULA"],
				                    NivelEscolaridade = [#"VIEW CODES - ESTAGIц│RIOS.NIVEL_ESCOLARIDADE"],
				                    MatServidor = [#"VIEW SEGESP -  SERVIDORES.MATRICULA"],
				                    CargoServidor = [#"VIEW SEGESP -  SERVIDORES.DESC_CARGO_ATUAL"],
				
				                    NivelTexto =
				                        if NivelEscolaridade <> null and Text.Trim(Text.From(NivelEscolaridade)) <> "" then
				                            Text.Proper(Text.Trim(Text.From(NivelEscolaridade)))
				                        else
				                            null,
				
				                    CargoTexto =
				                        if CargoServidor <> null and Text.Trim(Text.From(CargoServidor)) <> "" then
				                            Text.Proper(Text.Trim(Text.From(CargoServidor)))
				                        else
				                            null,
				
				                    TextoBase =
				                        if MatEstagiario <> null then
				                            Text.Combine(
				                                List.RemoveNulls({"Estagiц║rio", NivelTexto}),
				                                " - "
				                            )
				                        else if MatServidor <> null then
				                            Text.Combine(
				                                List.RemoveNulls({"Servidor", CargoTexto}),
				                                " - "
				                            )
				                        else
				                            "Nцёo localizado",
				
				                    Substituicoes = {
				                        {"Subescrivцёф▓o", "Subescrivцёo"},
				                        {"Escrivцёф▓o", "Escrivцёo"},
				                        {"CartцёБ─°Rio", "CartцЁrio"},
				                        {"Subsecretцёб│Rio", "Subsecretц║rio"},
				                        {"ServiцёБ─║O", "Serviцїo"},
				                        {"JustiцёБ─║A", "Justiцїa"},
				                        {"Judiciцёб│Rio", "Judiciц║rio"},
				                        {"TцёБ─╟Cnico", "Tц╘cnico"},
				                        {"Nцёб█Vel", "Nцґvel"},
				                        {"MцёБ─╟Dio", "Mц╘dio"},
				                        {"RecepцёБ─║ц┐ф▓o", "Recepцїцёo"},
				                        {"Artцёб█Fice", "Artцґfice"},
				                        {"Jurцёб█Dico", "Jurцґdico"},
				                        {"Secretцёб│Rio", "Secretц║rio"},
				                        {"Vice-Presidцёе║ncia", "Vice-Presidц╙ncia"},
				                        {"EletrцёБ─²Nico", "EletrцЄnico"},
				                        {"SeцёБ─║ц┐ф▓o", "Seцїцёo"},
				                        {"Secao", "Seцїцёo"},
				                        {"ExtinцёБ─║ц┐ф▓o", "Extinцїцёo"},
				                        {"Nц╒б╨", "Nб╨"},
				                        {"2ц┌б╙", "2б╙"},
				                        {"1ц┌б╙", "1б╙"},
				                        {"ц┌б╨", "б╨"},
				                        {"ц┌б╙", "б╙"},
				                        {"ц┐бї", "цї"},
				                        {"ц┐бё", "цё"},
				                        {"ц┐б║", "ц║"},
				                        {"ц┐ ", "ц═"},
				                        {"ц┐б╒", "ц╒"},
				                        {"ц┐б╙", "ц╙"},
				                        {"ц┐б╘", "ц╘"},
				                        {"ц┐бґ", "цґ"},
				                        {"ц┐бЁ", "цЁ"},
				                        {"ц┐бЄ", "цЄ"},
				                        {"ц┐б╣", "ц╣"},
				                        {"ц┐б╨", "ц╨"},
				                        {"ц┐Б─╟", "ц┴"},
				                        {"ц┐Б─°", "ц⌠"},
				                        {"ц┐Б─║", "ц┤"}
				                    },
				
				                    TextoCorrigido =
				                        List.Accumulate(
				                            Substituicoes,
				                            TextoBase,
				                            (estado, atual) => Text.Replace(estado, atual{0}, atual{1})
				                        ),
				
				                    Padronizacoes = {
				                        {" De ", " de "},
				                        {" Da ", " da "},
				                        {" Do ", " do "},
				                        {" Das ", " das "},
				                        {" Dos ", " dos "},
				                        {" E ", " e "},
				                        {" Lei ", " Lei "},
				                        {" -11915/2010", " - 11915/2010"},
				                        {" -11916/10", " - 11916/10"},
				                        {"-13967/18", " - 13967/18"},
				                        {"-5516/89", " - 5516/89"},
				                        {"-10845/07", " - 10845/07"},
				                        {"-56516/89", " - 5516/89"},
				                        {"-5772/90", " - 5772/90"},
				                        {"-6577/94", " - 6577/94"},
				                        {"-11916/10", " - 11916/10"},
				                        {"-13935/18", " - 13935/18"},
				                        {"Tecnico", "Tц╘cnico"},
				                        {"Juridico", "Jurцґdico"},
				                        {"Administrativo2б╙", "Administrativo 2б╙"},
				                        {"Saj", "SAJ"},
				                        {"2б╙ Vice-Presidц╙ncia", "2б╙ Vice-Presidц╙ncia"},
				                        {"1б╙ Vice-Presidц╙ncia", "1б╙ Vice-Presidц╙ncia"}
				                    },
				
				                    TextoPadronizado =
				                        List.Accumulate(
				                            Padronizacoes,
				                            TextoCorrigido,
				                            (estado, atual) => Text.Replace(estado, atual{0}, atual{1})
