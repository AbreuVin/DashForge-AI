	partition 'BASE AZURE - EMAILS' = m
		mode: import
		source =
				let
				    // ===== PARц┌METROS =====
				    Site = "https://tjbacotec.sharepoint.com/sites/axelab-controle-elosminuta-prd",
				    PastaAlvo = "https://tjbacotec.sharepoint.com/sites/axelab-controle-elosminuta-prd/Documentos Compartilhados/usuarios/",
				
				    // ===== FONTE SHAREPOINT =====
				    Fonte = SharePoint.Files(Site, [ApiVersion = 15]),
				
				    // ===== FILTRA ARQUIVOS QUE CONTENHAM "BASE AZURE" =====
				    ArquivosFiltrados =
				        Table.SelectRows(
				            Fonte,
				            each
				                [Folder Path] = PastaAlvo
				                and Text.Contains(Text.Upper([Name]), "BASE AZURE")
				                and (
				                    Text.EndsWith(Text.Lower([Name]), ".xlsx")
				                    or Text.EndsWith(Text.Lower([Name]), ".xls")
				                )
				        ),
				
				    // ===== PEGA O ARQUIVO MAIS RECENTE =====
				    ArquivosOrdenados =
				        Table.Sort(ArquivosFiltrados, {{"Date modified", Order.Descending}}),
				
				    ConteudoArquivo = ArquivosOrdenados{0}[Content],
				
				    // ===== IMPORTA O EXCEL =====
				    #"Pasta de Trabalho Importada do Excel" = Excel.Workbook(ConteudoArquivo),
				    AZURE_Sheet = #"Pasta de Trabalho Importada do Excel"{[Item="AZURE", Kind="Sheet"]}[Data],
				    #"Cabeцїalhos Promovidos" = Table.PromoteHeaders(AZURE_Sheet, [PromoteAllScalars=true]),
				    #"Tipo Alterado" = Table.TransformColumnTypes(#"Cabeцїalhos Promovidos", {{"userPrincipalName", type text}, {"displayName", type text}}),
				
				    #"Consultas Mescladas" =
