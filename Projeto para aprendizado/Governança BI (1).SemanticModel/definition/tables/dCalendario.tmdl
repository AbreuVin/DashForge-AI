	partition dCalendario = calculated
		mode: import
		source = ```
				
				
				VAR TabelaDisponibilidade =
				    SELECTCOLUMNS (
				        '1 Disponibilidade de Sistemas',
				        "DataUnificada", '1 Disponibilidade de Sistemas'[Data Início]
				    )
				VAR TabelaCapacitacoes =
				    SELECTCOLUMNS (
				        FILTER('2 Capacitações', NOT ISBLANK('2 Capacitações'[ANO]) && '2 Capacitações'[ANO] > 0 && '2 Capacitações'[ANO] <= 9999),
				        "DataUnificada", DATE ( '2 Capacitações'[ANO], 1, 1 )
				    )
				VAR TabelaContratacoes =
				    SELECTCOLUMNS (
				        FILTER('3 Contratações', NOT ISBLANK('3 Contratações'[ANO]) && '3 Contratações'[ANO] > 0 && '3 Contratações'[ANO] <= 9999),
				        "DataUnificada", DATE ( '3 Contratações'[ANO], 1, 1 )
				    )
				VAR TabelaIGovTIC =
				    SELECTCOLUMNS (
				        FILTER('4 iGovTIC', NOT ISBLANK('4 iGovTIC'[ANO]) && '4 iGovTIC'[ANO] > 0 && '4 iGovTIC'[ANO] <= 9999),
				        "DataUnificada", DATE ( '4 iGovTIC'[ANO], 1, 1 )
				    )
				VAR TabelaSatisfacao =
				    SELECTCOLUMNS (
				        '5 Satisfação Service Desk',
				        "DataUnificada", '5 Satisfação Service Desk'[Data da Resposta]
				    )
				VAR TabelaCadastroContratos = 
				    SELECTCOLUMNS(
				        FILTER(
				            'Cadastro de Contratos',
				            NOT ISBLANK('Cadastro de Contratos'[Exercício (Ano)]) && 'Cadastro de Contratos'[Exercício (Ano)] > 0 && 'Cadastro de Contratos'[Exercício (Ano)] <= 9999
				        ),
				        "DataUnificada", DATE('Cadastro de Contratos'[Exercício (Ano)], 1, 1)
				    )
				VAR TabelaPagamentoMensal = 
				    SELECTCOLUMNS(
				        FILTER(
				            'Pagamento Mensal Por Natureza',
				            NOT ISBLANK('Pagamento Mensal Por Natureza'[Ano]) && 'Pagamento Mensal Por Natureza'[Ano] > 0 && 'Pagamento Mensal Por Natureza'[Ano] <= 9999
				        ),
				        "DataUnificada", DATE('Pagamento Mensal Por Natureza'[Ano], 1, 1) 
				    )
				VAR TabelaDotacao = 
				    SELECTCOLUMNS(
				        FILTER(
				            'Dotação',
				            NOT ISBLANK('Dotação'[Ano]) && 'Dotação'[Ano] > 0 && 'Dotação'[Ano] <= 9999
				        ),
				        "DataUnificada", DATE('Dotação'[Ano], 1, 1)
				    )
				VAR TodasAsDatas =
				    UNION (
				        TabelaDisponibilidade,
				        TabelaCapacitacoes,
				        TabelaContratacoes,
				        TabelaIGovTIC,
				        TabelaSatisfacao,
				        TabelaCadastroContratos,
				        TabelaPagamentoMensal,
				        TabelaDotacao
				    )
				
				VAR MinhaDataMinima = MINX( TodasAsDatas, [DataUnificada] )
				VAR MinhaDataMaxima = MAXX( TodasAsDatas, [DataUnificada] )
				
				
				RETURN
				    ADDCOLUMNS (
				        CALENDAR ( MinhaDataMinima, MinhaDataMaxima ),
				        "Ano", YEAR ( [Date] ),
				        "Trimestre", "T" & FORMAT ( [Date], "q" ),
				        "Mês Num", MONTH ( [Date] ),
				        "Nome Mês", FORMAT ( [Date], "mmmm" ),
				        "Mês Abrev", FORMAT ( [Date], "mmm" ),
				        "Ano-Mês", FORMAT ( [Date], "yyyy-mm" ),
				        "Dia", DAY ( [Date] ),
				        "Dia da Semana", WEEKDAY ( [Date], 2 ),
				        "Nome Dia Semana", FORMAT ( [Date], "dddd" )
				    )
				```

	annotation PBI_Id = f71a2e3d9cb346f591e1d79df44b7beb

